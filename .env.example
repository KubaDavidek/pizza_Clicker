# Zkopíruj tento soubor do .env a vyplň hodnoty.
# .env je gitignorovaný a nikdy se necommituje.

# Povinné: náhodný řetězec pro podepisování session cookies.
# Vygeneruj: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Volitelné: bez DATABASE_URL se použije lokální SQLite (pizza_clicker.db).
# Pro Supabase produkci:
# DATABASE_URL=postgresql://postgres:heslo@db.xxxx.supabase.co:5432/postgres

# Volitelné: zapne Flask debug mode lokálně.
# FLASK_DEBUG=1
