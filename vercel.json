{
  "version": 2,
  "builds": [
    {
      "src": "server.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["validation.py", "logging_config.py"]
      }
    },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.py" },
    { "src": "/css/(.*)", "dest": "src/css/$1" },
    { "src": "/js/(.*)", "dest": "src/js/$1" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
